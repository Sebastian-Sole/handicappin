{
  "name": "handicappin",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace orchestrator. Web app: apps/web. Native app: apps/native. Shared packages: packages/*.",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:native": "pnpm --filter native start",
    "dev:all": "concurrently -n web-stack,native,parity -c blue,cyan,magenta \"pnpm --filter web dev:all\" \"pnpm --filter native start\" \"pnpm run parity:watch\"",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "test": "pnpm --filter web test",
    "test:unit": "pnpm --filter web test:unit",
    "test:integration": "pnpm --filter web test:integration",
    "test:coverage": "pnpm --filter web test:coverage",
    "email": "pnpm --filter web email",
    "gen:types": "pnpm --filter web gen:types",
    "gen:local": "pnpm --filter web gen:local",
    "storybook": "pnpm --filter web storybook",
    "build:seed": "./scripts/build-seed.sh",
    "check:schema-sync": "node scripts/check-schema-sync.mjs",
    "check:tokens": "bash scripts/check-design-tokens.sh",
    "generate:theme": "pnpm --filter @handicappin/tokens generate:theme",
    "check:theme-drift": "pnpm --filter @handicappin/tokens check:drift",
    "parity": "pnpm run check:theme-drift && pnpm run parity:routes && pnpm run parity:styles",
    "parity:routes": "node scripts/parity/routes.mjs",
    "parity:drift": "node scripts/parity/drift.mjs",
    "parity:watch": "node scripts/parity/watch.mjs",
    "parity:styles": "node scripts/parity/check-hardcoded-styles.mjs"
  },
  "pnpm": {
    "overrides": {
      "@types/react-dom": "19.2.3",
      "import-in-the-middle": "1.15.0",
      "require-in-the-middle": "7.5.2",
      "lightningcss": "1.30.1"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}