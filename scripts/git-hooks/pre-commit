#!/usr/bin/env bash
# Pre-commit gate (installed by scripts/install-hooks.sh; applies to anyone
# committing, human or agent). Fast checks:
#
#   1. Design-token sync — if the design-system source changed, regenerate
#      @handicappin/tokens and stage the outputs so commits never carry a
#      stale token contract (CI backstop: check:theme-drift).
#   2. check:tokens — the web-side token-bypass guard.
#   3. parity:routes — web/native route divergence (dormant until apps/native).
#   4. parity:styles — hardcoded native styling (dormant until apps/native).
#
# Deterministic and sub-second; bypass only with --no-verify.
set -uo pipefail
cd "$(git rev-parse --show-toplevel)" || exit 1

TOKEN_SOURCES='^(apps/web/app/globals\.css|apps/web/app/styles/utilities/|packages/tokens/(src/|theme\.config\.json))'

if git diff --cached --name-only | grep -qE "$TOKEN_SOURCES"; then
  echo "[pre-commit] design-token source changed — regenerating @handicappin/tokens"
  if ! pnpm --filter @handicappin/tokens generate:theme >/dev/null 2>&1; then
    echo "[pre-commit] generate:theme FAILED — fix the token source before committing:"
    pnpm --filter @handicappin/tokens generate:theme
    exit 1
  fi
  git add packages/tokens/generated
fi

if ! bash scripts/check-design-tokens.sh; then
  echo "[pre-commit] check:tokens failed — commit blocked."
  exit 1
fi

if ! node scripts/parity/routes.mjs >/dev/null; then
  echo "[pre-commit] parity:routes failed — route sets diverged. Details:"
  node scripts/parity/routes.mjs || true
  exit 1
fi

if ! node scripts/parity/check-hardcoded-styles.mjs; then
  echo "[pre-commit] parity:styles failed — hardcoded native styling. Commit blocked."
  exit 1
fi

exit 0
