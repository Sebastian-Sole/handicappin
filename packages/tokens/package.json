{
  "name": "@handicappin/tokens",
  "version": "0.0.1",
  "private": true,
  "description": "Generated design tokens for the future native app. Source of truth is app/globals.css + app/styles/utilities/* (read-only). Run generate:theme to re-sync.",
  "type": "module",
  "exports": {
    "./tokens": {
      "types": "./generated/tokens.ts",
      "default": "./generated/tokens.ts"
    },
    "./font-faces": "./src/font-faces.mjs",
    "./theme.config.json": "./theme.config.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate:theme": "node ./src/generate.mjs",
    "check:drift": "node ./src/generate.mjs && git diff --exit-code -- generated ../../apps/native/global.css",
    "check-types": "tsc --noEmit --strict --skipLibCheck --moduleResolution bundler --module esnext ./generated/tokens.ts",
    "test": "node --test"
  },
  "devDependencies": {
    "postcss": "^8.5.6",
    "typescript": "^5.8.3"
  }
}
