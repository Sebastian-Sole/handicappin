{
  "source": "../../app/globals.css",
  "typographySource": "../../app/styles/utilities/typography.css",
  "surfacesSource": "../../app/styles/utilities/surfaces.css",
  "themeInlineBlock": "@theme inline",
  "lightSelector": ":root",
  "darkSelector": ".dark",
  "outputDir": "./generated",
