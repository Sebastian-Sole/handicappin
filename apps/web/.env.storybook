# Placeholder env vars for Storybook.
#
# `env.ts` uses @t3-oss/env-nextjs + zod and validates required env vars at
# module-eval time. Stories that transitively import `@/env` would crash
# without these. Values are fake but pass zod validation (URLs are URLs,
# strings are non-empty). Loaded by `.storybook/main.ts` via dotenv before
# Storybook's config is exported.
#
# Server vars are also stubbed here so any accidental import (despite the
# `@/db` / `@/server/api/root` aliases) doesn't break env validation.

# Client (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://storybook.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=storybook-anon-key-placeholder
NEXT_PUBLIC_GOOGLE_CLIENT_ID=storybook-google-client-id

# Server
DATABASE_URL=postgres://storybook:storybook@localhost:5432/storybook
RESEND_API_KEY=storybook-resend-key
SEND_EMAIL_HOOK_SECRET=storybook-send-email-hook-secret
STRIPE_SECRET_KEY=sk_test_storybook
STRIPE_WEBHOOK_SECRET=whsec_storybook
STRIPE_PREMIUM_PRICE_ID=price_storybook_premium
STRIPE_UNLIMITED_PRICE_ID=price_storybook_unlimited
STRIPE_UNLIMITED_LIFETIME_PRICE_ID=price_storybook_unlimited_lifetime
KV_URL=https://storybook.kv.example.com
KV_REST_API_URL=https://storybook.kv-rest.example.com
KV_REST_API_TOKEN=storybook-kv-token
KV_REST_API_READ_ONLY_TOKEN=storybook-kv-readonly-token
REDIS_URL=https://storybook.redis.example.com
ADMIN_ALERT_EMAILS=storybook@example.com
RESET_TOKEN_SECRET=storybook-reset-token-secret
OPENAI_API_KEY=storybook-openai-key
GOOGLE_CLIENT_SECRET=storybook-google-client-secret
SUPABASE_SERVICE_ROLE_KEY=storybook-supabase-service-role-key
HANDICAP_CRON_SECRET=storybook-handicap-cron-secret
STRIPE_CRON_SECRET=storybook-stripe-cron-secret
